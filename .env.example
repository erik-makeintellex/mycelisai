# Mycelis Project Environment Variables
# Copy this file to .env and adjust values as needed.

# --- Database (PostgreSQL) ---
# Used by Core Service and Infrastructure
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=mycelis
DB_PASSWORD=password
DB_NAME=cortex

# --- Infrastructure ---
# Native dev PostgreSQL bootstrap user/password. Compose uses .env.compose.
POSTGRES_PASSWORD=password
POSTGRES_USER=postgres
POSTGRES_DB=cortex

# --- Core Service ---
# API Listening Port
PORT=8080

# --- NATS ---
# Native dev NATS URL. Compose/K8s override this inside their runtime lanes.
NATS_URL=nats://127.0.0.1:4222
MYCELIS_DEV_INFRA_MODE=native

# --- Phase 0: Security ---
# API authentication key (server refuses to start without this)
# Generate/update a local dev key with:
#   uv run inv auth.dev-key
MYCELIS_API_KEY=mycelis-dev-key-change-in-prod
MYCELIS_WEB_SESSION_SECRET=mycelis-web-session-secret-change-in-prod
# Optional: use a separate HMAC secret for Interface -> Core web identity forwarding.
# When unset, Core and Interface use MYCELIS_WEB_SESSION_SECRET for signed browser identity propagation.
MYCELIS_WEB_IDENTITY_FORWARD_SECRET=
# Primary self-hosted local admin identity
MYCELIS_LOCAL_ADMIN_USERNAME=admin
MYCELIS_LOCAL_ADMIN_USER_ID=00000000-0000-0000-0000-000000000000
# Optional break-glass recovery principal for explicit self-hosted recovery
MYCELIS_BREAK_GLASS_API_KEY=mycelis-break-glass-key-change-in-prod
MYCELIS_BREAK_GLASS_USERNAME=recovery-admin
MYCELIS_BREAK_GLASS_USER_ID=00000000-0000-0000-0000-000000000001
# Compose self-hosted search secret used by the SearXNG service.
MYCELIS_SEARXNG_SECRET=mycelis-compose-search-change-in-prod
# Governed search defaults to local_sources so Soma can use retained Mycelis
# context without hosted search tokens. Use searxng or local_api for public web.
MYCELIS_SEARCH_PROVIDER=local_sources
MYCELIS_SEARCH_MAX_RESULTS=8
# Optional hosted OpenAI proof path. Keep the real key only in local .env.
OPENAI_API_KEY=
MYCELIS_PROVIDER_PRODUCTION_GPT4_MODEL_ID=gpt-4.1-nano
MYCELIS_PROVIDER_PRODUCTION_GPT4_ENABLED=false
# Local/private media generation path. Point Core at the Mycelis media gateway,
# then point the gateway at a Pinokio-hosted Forge/AUTOMATIC1111 API.
MYCELIS_MEDIA_PROVIDER_ID=pinokio-local
MYCELIS_MEDIA_TYPE=openai_compatible
MYCELIS_MEDIA_ENDPOINT=http://127.0.0.1:8001/v1
MYCELIS_MEDIA_MODEL_ID=local-media
MYCELIS_MEDIA_LOCATION=local
MYCELIS_MEDIA_DATA_BOUNDARY=local_only
MYCELIS_MEDIA_USAGE_POLICY=local_first
MYCELIS_MEDIA_API_KEY_ENV=
MYCELIS_MEDIA_ENABLED=true
MYCELIS_MEDIA_GATEWAY_BACKEND=forge
MYCELIS_MEDIA_GATEWAY_UPSTREAM=http://127.0.0.1:7860
MYCELIS_MEDIA_GATEWAY_TIMEOUT_SECONDS=300
# Public/non-private upstreams are blocked by default for local/private media proof.
MYCELIS_MEDIA_GATEWAY_ALLOW_PUBLIC_UPSTREAM=0
# ComfyUI local backend option. Use only when MYCELIS_MEDIA_GATEWAY_BACKEND=comfyui.
# Export an API-format workflow from ComfyUI, map the node receiving Soma's prompt,
# and optionally map the latent/size node so requested image dimensions transmit.
# MYCELIS_MEDIA_GATEWAY_UPSTREAM=http://127.0.0.1:8188
# MYCELIS_MEDIA_GATEWAY_COMFY_WORKFLOW_FILE=./workspace/media/comfyui-workflow.json
# MYCELIS_MEDIA_GATEWAY_COMFY_PROMPT_NODE_ID=6
# MYCELIS_MEDIA_GATEWAY_COMFY_PROMPT_INPUT=text
# MYCELIS_MEDIA_GATEWAY_COMFY_SIZE_NODE_ID=5
# MYCELIS_MEDIA_GATEWAY_COMFY_WIDTH_INPUT=width
# MYCELIS_MEDIA_GATEWAY_COMFY_HEIGHT_INPUT=height
# MYCELIS_MEDIA_GATEWAY_COMFY_BATCH_NODE_ID=5
# MYCELIS_MEDIA_GATEWAY_COMFY_BATCH_INPUT=batch_size
# MYCELIS_MEDIA_GATEWAY_COMFY_POLL_SECONDS=1
# Output and workspace roots.
#
# MYCELIS_WORKSPACE is the governed workspace where generated files,
# filesystem MCP work, playable projects, and retained browser outputs land.
# In native source mode this is relative to the Core process directory.
MYCELIS_WORKSPACE=./workspace
# MYCELIS_ARTIFACT_ROOT stores file-backed artifact/cache payloads.
# In Kubernetes this should live on the mounted /data volume, e.g. /data/artifacts.
MYCELIS_ARTIFACT_ROOT=./workspace/artifacts
# Legacy alias honored by older runtime paths. Keep it aligned until removed.
DATA_DIR=./workspace/artifacts
