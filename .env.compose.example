# Copy to .env.compose for the Docker Compose home-runtime path.
# This file is intentionally separate from .env so Kind/K8s and Compose can
# keep their own host/runtime assumptions without fighting each other.

MYCELIS_API_KEY=mycelis-dev-key-change-in-prod
MYCELIS_LOCAL_ADMIN_USERNAME=admin
MYCELIS_LOCAL_ADMIN_USER_ID=00000000-0000-0000-0000-000000000000
MYCELIS_BREAK_GLASS_API_KEY=mycelis-break-glass-key-change-in-prod
MYCELIS_BREAK_GLASS_USERNAME=recovery-admin
MYCELIS_BREAK_GLASS_USER_ID=00000000-0000-0000-0000-000000000001
MYCELIS_BOOTSTRAP_TEMPLATE_ID=v8-migration-standing-team-bridge

POSTGRES_USER=mycelis
POSTGRES_PASSWORD=password
POSTGRES_DB=cortex

DB_HOST=postgres
DB_PORT=5432
DB_USER=mycelis
DB_PASSWORD=password
DB_NAME=cortex

NATS_URL=nats://nats:4222

# Docker Compose publishes the same host ports the local tasking path expects.
MYCELIS_COMPOSE_POSTGRES_PORT=5432
MYCELIS_COMPOSE_NATS_PORT=4222
MYCELIS_COMPOSE_NATS_MONITOR_PORT=8222
MYCELIS_COMPOSE_CORE_PORT=8081
MYCELIS_COMPOSE_INTERFACE_PORT=3000

# Default home-runtime posture uses a host Ollama instance.
# On Docker Desktop, host.docker.internal resolves automatically.
# On Linux Docker Engine, the compose file adds host-gateway for the core service.
MYCELIS_COMPOSE_OLLAMA_HOST=http://host.docker.internal:11434

# The slim home-runtime Core image does not bundle npm/npx for default local MCP
# subprocess installation. Leave this on unless you are extending the image or
# wiring MCP servers some other way.
MYCELIS_DISABLE_DEFAULT_MCP_BOOTSTRAP=true

CORS_ORIGIN=http://localhost:3000

# Output block storage mounted into Core at /data.
# Use local_hosted for Docker Compose or a Pinokio/local-media host directory.
# Use cluster_generated in Kubernetes/cluster docs where the chart PVC owns /data.
# When local_hosted, provide a real host directory path that Docker can mount.
# Relative paths are resolved from the repo root; ~ and environment variables are
# expanded by the Invoke compose task with Python pathlib before Compose runs.
MYCELIS_OUTPUT_BLOCK_MODE=local_hosted
MYCELIS_OUTPUT_HOST_PATH=./workspace/docker-compose/data
DATA_DIR=/data/artifacts
MYCELIS_WORKSPACE=/data/workspace
